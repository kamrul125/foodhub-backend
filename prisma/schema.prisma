generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  SELLER
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  
  // সেলার হিসেবে যে খাবারগুলো যোগ করেছে
  foods     Food[]   
  // কাস্টমার হিসেবে যে অর্ডারগুলো করেছে
  orders    Order[]  
  
  createdAt DateTime @default(now())
}

model Food {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  // খাবারের বর্ণনা
  price       Float
  image       String?  // খাবারের ছবির URL
  category    String?  // যেমন: বার্গার, পিজ্জা, ড্রিংকস
  
  // সেলারের সাথে রিলেশন
  sellerId    Int
  seller      User     @relation(fields: [sellerId], references: [id])
  
  // অর্ডারের সাথে রিলেশন
  orders      Order[] 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id          Int      @id @default(autoincrement())
  
  // ইউজারের সাথে রিলেশন (কে অর্ডার করেছে)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  
  // খাবারের সাথে রিলেশন
  foods       Food[]   
  
  status      String   @default("PENDING") // PENDING, DELIVERED, CANCELLED
  totalAmount Float    @default(0)
  address     String?  // ডেলিভারি এড্রেস (রিকোয়ারমেন্টে থাকতে পারে)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}